# ============================================
# ADIPA Coupon Service — Version B (Laravel)
# ============================================

# Laravel core
APP_NAME="ADIPA Coupon Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Autenticación del microservicio (header X-API-Key)
API_KEY=changeme

# WooCommerce REST API v3
# Las credenciales se generan automáticamente en el primer docker compose up
WC_BASE_URL=http://wordpress:80
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# Reglas de negocio
# Monto máximo para descuentos de tipo fixed_cart/fixed_product (en COP)
MAX_FIXED_DISCOUNT=500000

# Base de datos local del microservicio (SQLite — independiente de la DB de WordPress)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/app/database/coupons.sqlite

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
