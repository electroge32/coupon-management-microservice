{
  "info": {
    "_postman_id": "adipa-coupon-service-001",
    "name": "ADIPA Coupon Service",
    "description": "Collection for ADIPA Coupon Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "apiKey",
      "value": "changeme"
    }
  ],
  "item": [
    {
      "name": "Create Coupon (birthday)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"birthday\",\"discount_type\":\"percent\",\"amount\":50,\"email\":\"test@example.com\"}"
        }
      }
    },
    {
      "name": "Create Coupon (partner)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"partner\",\"discount_type\":\"percent\",\"amount\":20,\"partner_code\":\"CNVN\"}"
        }
      }
    },
    {
      "name": "Create Coupon (campaign)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"campaign\",\"discount_type\":\"percent\",\"amount\":15,\"prefix\":\"PROMO\",\"expires_at\":\"2026-12-31T23:59:59\"}"
        }
      }
    },
    {
      "name": "Bulk Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/bulk",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "bulk"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"gift_card\",\"discount_type\":\"fixed_cart\",\"amount\":50000,\"quantity\":5}"
        }
      }
    },
    {
      "name": "List Coupons",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons?type=birthday&page=1&per_page=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons"],
          "query": [
            {
              "key": "type",
              "value": "birthday"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "per_page",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Coupon",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/BD-ABC123",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "BD-ABC123"]
        }
      }
    },
    {
      "name": "Validate Coupon",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/BD-ABC123/validate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "BD-ABC123", "validate"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"test@example.com\",\"product_ids\":[]}"
        }
      }
    },
    {
      "name": "Apply Coupon",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/BD-ABC123/apply",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "BD-ABC123", "apply"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"test@example.com\",\"order_id\":\"ORD-001\"}"
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "health"]
        }
      }
    }
  ]
}
