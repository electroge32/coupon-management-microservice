# ============================================
# ADIPA Coupon Service — Version A (FastAPI)
# ============================================

# Autenticación del microservicio (header X-API-Key)
API_KEY=changeme

# WooCommerce REST API v3
# Las credenciales se generan automáticamente en el primer docker compose up
WC_BASE_URL=http://wordpress:80
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# Reglas de negocio
# Monto máximo para descuentos de tipo fixed_cart/fixed_product (en COP)
MAX_FIXED_DISCOUNT=500000

# Base de datos local del microservicio
DATABASE_URL=sqlite:///./coupons.db
